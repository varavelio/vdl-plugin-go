"package gen

import (
	"encoding/json"
	"fmt"
)

// Tier defines a generated enum.
type Tier string

// Tier constants define the declared values of Tier.
const (
	TierFree Tier = "free"
	TierPro Tier = "pro"
	TierEnterprise Tier = "enterprise"
)

// TierList contains every valid Tier value.
var TierList = []Tier{
	TierFree,
	TierPro,
	TierEnterprise,
}

// String returns a readable representation of Tier.
func (e Tier) String() string {
	return string(e)
}

// IsValid reports whether the value belongs to Tier.
func (e Tier) IsValid() bool {
	switch e {
		case TierFree, TierPro, TierEnterprise:
			return true
	}
	return false
}

// MarshalJSON encodes Tier and rejects values outside the declared enum set.
func (e Tier) MarshalJSON() ([]byte, error) {
	if !e.IsValid() {
		return nil, fmt.Errorf("cannot marshal invalid value %q for Tier enum", string(e))
	}
	return json.Marshal(string(e))
}

// UnmarshalJSON decodes Tier and rejects values outside the declared enum set.
func (e *Tier) UnmarshalJSON(data []byte) error {
	var value string
	if err := json.Unmarshal(data, &value); err != nil {
		return err
	}
	candidate := Tier(value)
	if !candidate.IsValid() {
		return fmt.Errorf("invalid value %q for Tier enum", value)
	}
	*e = candidate
	return nil
}"
`;

