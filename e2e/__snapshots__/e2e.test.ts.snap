type VDLAnnotationSet struct {
	List []VDLAnnotation
	ByName map[string]any
}

// Has reports whether an annotation exists in the set.
func (a VDLAnnotationSet) Has(name string) bool {
	_, ok := a.ByName[name]
	return ok
}

// Get returns the latest value associated with the annotation name.
func (a VDLAnnotationSet) Get(name string) (any, bool) {
	value, ok := a.ByName[name]
	return value, ok
}

// VDLTypeRef describes the recursive shape of a VDL type.
type VDLTypeRef struct {
	Kind string
	Name string
	ArrayDims int
	Element *VDLTypeRef
	Fields map[string]VDLFieldMetadata
}

// GetField looks up an object field by its generated Go name.
func (r VDLTypeRef) GetField(name string) (VDLFieldMetadata, bool) {
	field, ok := r.Fields[name]
	return field, ok
}

// VDLFieldMetadata describes a generated field.
type VDLFieldMetadata struct {
	Name string
	JSONName string
	Optional bool
	Type VDLTypeRef
	Annotations VDLAnnotationSet
}

// VDLTypeMetadata describes a generated type.
