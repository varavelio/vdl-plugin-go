	StatusUnknown,
	StatusReady,
	StatusFailed,
}

// String returns a readable representation of Status.
func (e Status) String() string {
	return string(e)
}

// IsValid reports whether the value belongs to Status.
func (e Status) IsValid() bool {
	switch e {
		case StatusUnknown, StatusReady, StatusFailed:
			return true
	}
	return false
}

// MarshalJSON encodes Status and rejects values outside the declared enum set.
func (e Status) MarshalJSON() ([]byte, error) {
	if !e.IsValid() {
		return nil, fmt.Errorf("cannot marshal invalid value %q for Status enum", string(e))
