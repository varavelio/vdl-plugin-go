const (
	StatusReady Status = "ready"
	StatusPaused Status = "paused"
)

// StatusList contains every valid Status value.
var StatusList = []Status{
	StatusReady,
	StatusPaused,
}

// String returns the string representation of Status.
func (e Status) String() string {
	return string(e)
}

// IsValid reports whether the value belongs to Status.
func (e Status) IsValid() bool {
	switch e {
		case StatusReady, StatusPaused:
			return true
	}
	return false
}

// MarshalJSON implements json.Marshaler.
func (e Status) MarshalJSON() ([]byte, error) {
	if !e.IsValid() {
		return nil, fmt.Errorf("cannot marshal invalid value for enum Status")
	}
	return json.Marshal(string(e))
}

// UnmarshalJSON implements json.Unmarshaler.
func (e *Status) UnmarshalJSON(data []byte) error {
	var value string
	if err := json.Unmarshal(data, &value); err != nil {
		return err
	}
	candidate := Status(value)
	if !candidate.IsValid() {
		return fmt.Errorf("invalid value for enum Status")
	}
	*e = candidate
	return nil
}

// Payload is a VDL object type.
type Payload struct {
	Name string \`json:"name"\`
	Status Status \`json:"status"\`
	Items []PayloadItems \`json:"items"\`
	StatusesByName map[string]Status \`json:"statusesByName"\`
	Note *string \`json:"note,omitempty"\`
}

// prePayload is the presence-aware JSON form of Payload.
type prePayload struct {
	Name *string \`json:"name"\`
	Status *Status \`json:"status"\`
	Items *[]PayloadItems \`json:"items"\`
	StatusesByName *map[string]Status \`json:"statusesByName"\`
	Note *string \`json:"note,omitempty"\`
}

// validate checks JSON field presence for Payload.
func (p *prePayload) validate() error {
	if p.Name == nil {
		return fmt.Errorf("field %q is required", "name")
	}
	if p.Status == nil {
		return fmt.Errorf("field %q is required", "status")
	}
	if p.Items == nil {
		return fmt.Errorf("field %q is required", "items")
	}
	if p.StatusesByName == nil {
		return fmt.Errorf("field %q is required", "statusesByName")
	}
	return nil
}

// transform converts prePayload into Payload.
func (p *prePayload) transform() Payload {
	return Payload{
		Name: *p.Name,
		Status: *p.Status,
		Items: *p.Items,
		StatusesByName: *p.StatusesByName,
		Note: p.Note,
	}
}

// UnmarshalJSON implements json.Unmarshaler.
func (x *Payload) UnmarshalJSON(data []byte) error {
	var pre prePayload
	if err := json.Unmarshal(data, &pre); err != nil {
		return err
	}
	if err := pre.validate(); err != nil {
		return err
	}
	*x = pre.transform()
	return nil
}

