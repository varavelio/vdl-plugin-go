exports[`E2E: VDL to Go > compiles fixture: misc-annotations > types.go 1`] = `
"package gen

import (
	"encoding/json"
	"fmt"
)

// User represents a VDL object.
type User struct {
	Id string \`json:"id"\`
}

// preUser mirrors User during strict JSON decoding.
type preUser struct {
	Id *string \`json:"id"\`
}

// validate reports whether preUser satisfies strict JSON requirements.
func (p *preUser) validate(parentPath string) error {
	vdlPathId := "id"
	if parentPath != "" {
		vdlPathId = parentPath + ".id"
	}
	if p.Id == nil {
		return fmt.Errorf("field %s is required", vdlPathId)
	}
	return nil
}

// transform converts preUser to User.
func (p *preUser) transform() User {
	var transId string
	transId = *p.Id

	return User{
		Id: transId,
	}
}

// UnmarshalJSON decodes User while requiring every non-optional JSON field.
func (x *User) UnmarshalJSON(data []byte) error {
	var pre preUser
	if err := json.Unmarshal(data, &pre); err != nil {
		return err
	}
	if err := pre.validate(""); err != nil {
		return err
	}
	*x = pre.transform()
	return nil
}

// GetId returns the Id field. It returns the zero value when the receiver is nil.
func (x *User) GetId() string {
	if x != nil {
		return x.Id
	}
	var zero string
	return zero
}

// GetIdOr returns the Id field. It returns defaultValue when the receiver is nil.
func (x *User) GetIdOr(defaultValue string) string {
	if x != nil {
		return x.Id
	}
	return defaultValue
}"
`;

